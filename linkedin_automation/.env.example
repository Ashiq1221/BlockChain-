# LinkedIn Credentials (required)
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password_here

# LinkedIn API credentials (optional — needed for content posting via API)
# Get these from: https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=your_access_token_here
LINKEDIN_PERSON_URN=your_person_urn_here

# Job Search Defaults
JOB_KEYWORDS=Python Developer
JOB_LOCATION=Remote

# Browser Settings
HEADLESS=false
SLOW_MO=50
