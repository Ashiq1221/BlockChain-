# ── Copy to .env and fill in your values ─────────────────────────────────────
# To activate:  export $(grep -v '^#' .env | xargs)

# Your SMMFollows API key
# → Log in at https://smmfollows.com  →  Top-right menu  →  API
SMM_API_KEY=YOUR_SMMFOLLOWS_API_KEY

# Anthropic / Claude API key (for AI decision-making & comment generation)
# → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Discover service IDs by running:  python agent.py list-services
SMM_LIKES_SVC=1
SMM_COMMENTS_SVC=2
SMM_RETWEETS_SVC=3

# Quantities per order
SMM_LIKES_QTY=100
SMM_COMMENTS_QTY=10
SMM_RETWEETS_QTY=50

# Comma-separated Twitter/X post URLs to boost
SMM_TARGET_LINKS=https://twitter.com/yourhandle/status/000000000000000000
