# Copy this file to .env and fill in your values
# then:  export $(cat .env | xargs)   OR use python-dotenv

SMM_API_KEY=your_smmfollows_api_key_here

# Service IDs – run `python smm_bot.py list-services` to find correct IDs
SMM_LIKES_SVC=1
SMM_COMMENTS_SVC=2
SMM_RETWEETS_SVC=3

# Comma-separated list of post URLs to boost
SMM_TARGET_LINKS=https://twitter.com/yourhandle/status/000000000000000000
