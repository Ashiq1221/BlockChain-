# Copy to .env and fill in your values

# ── SMMFollows panel ──────────────────────────────────────────────────────────
# Log in at https://smmfollows.com → Profile (top-right) → API
SMM_API_KEY=YOUR_SMMFOLLOWS_API_KEY

# Panel login (used for refill / ticket endpoints)
SMM_USER=your_username
SMM_PASS=your_password

# ── AI providers ──────────────────────────────────────────────────────────────
# Cloudflare Workers AI token (primary AI — DeepSeek R1 via Cloudflare)
# Create at https://dash.cloudflare.com → My Profile → API Tokens
# Required permissions: Workers AI (Account) — Run Models
DEEPSEEK_API_KEY=cfut_YOUR_CLOUDFLARE_AI_TOKEN
HAPPY_HORSE_API_KEY=cfut_YOUR_SECOND_CLOUDFLARE_TOKEN

# Cloudflare account ID (visible in dash.cloudflare.com URL / right sidebar)
CF_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID

# Cloudflare Workers AI model (default: DeepSeek R1 distill)
CF_AI_MODEL=@cf/deepseek-ai/deepseek-r1-distill-qwen-32b

# Anthropic / Claude API key (fallback — only used if Cloudflare AI fails)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY

# ── Verified Twitter/X service IDs ────────────────────────────────────────────
# ID 12452 → Twitter Likes Turkey HQ    | $0.88/1k | refill:YES | min:10
# ID 7338  → Twitter Comments USA        | $28.13/1k            | min:5
# ID 13139 → Twitter Retweets HQ         | $0.54/1k | refill:YES | min:10
# ID 17682 → Twitter Views HQ            | $1.50/1k             | min:100
SMM_LIKES_SVC=12452
SMM_COMMENTS_SVC=7338
SMM_RETWEETS_SVC=13139
