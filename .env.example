# ─── Telegram API ─────────────────────────────────────────────────
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+1234567890        # Your phone number with country code
TELEGRAM_SESSION_NAME=my_session  # Session file name (no extension)

# ─── AI Providers (system auto-switches when one runs out of credits) ─
ANTHROPIC_API_KEY=sk-ant-...         # https://console.anthropic.com
OPENAI_API_KEY=sk-...                # https://platform.openai.com  (ChatGPT fallback)
GEMINI_API_KEY=AIza...               # https://aistudio.google.com  (FREE fallback)

# ─── Agent Behavior ───────────────────────────────────────────────
AGENT_LANGUAGE=en                 # Response language
AGENT_PERSONA=Professional, sharp, concise. Sounds human, never robotic.
MAX_DM_PER_HOUR=10
MAX_GROUP_POSTS_PER_HOUR=5
RATE_LIMIT_SLEEP=3                # Seconds between Telegram actions
AUTO_RESPOND=true                 # Auto-respond to incoming DMs
JOB_KEYWORDS=python developer,blockchain engineer,backend engineer,remote developer

# ─── Optional web search ──────────────────────────────────────────
# Leave blank to skip web-search enrichment
SERPAPI_KEY=
