# ─── Telegram API ─────────────────────────────────────────────────
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+1234567890        # Your phone number with country code
TELEGRAM_SESSION_NAME=my_session  # Session file name (no extension)

# ─── Telegram Bot ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=               # From @BotFather
TELEGRAM_OWNER_ID=                # Your Telegram user ID (from @userinfobot)

# ─── AI Providers ─────────────────────────────────────────────────
# All 5 providers race simultaneously — fastest wins.
# Add any keys you have — system uses whatever is available.
ANTHROPIC_API_KEY=sk-ant-...         # https://console.anthropic.com
OPENAI_API_KEY=sk-...                # https://platform.openai.com
GEMINI_API_KEY=AIza...               # https://aistudio.google.com  (FREE)
GROQ_API_KEY=gsk_...                 # https://console.groq.com     (FREE)
DEEPSEEK_API_KEY=sk-...              # https://platform.deepseek.com

# Multi-key pools (up to 5 keys each — add _1, _2, _3 for higher rate limits)
# OPENAI_KEY_1=sk-...
# OPENAI_KEY_2=sk-...
# GEMINI_KEY_1=AIza...
# GROQ_KEY_1=gsk_...

# ─── Cloudflare (AI Gateway + Workers AI + KV) ────────────────────
CF_ACCOUNT_ID=92d3158363256e88393822c9ece2fb48     # Your CF account ID
CF_EMAIL=ashiqah18008@gmail.com                     # CF account email
CF_GLOBAL_KEY=                                      # CF Global API Key (Profile → API Tokens)
CF_KV_NAMESPACE=cda8b9f468204833a58d79d9409133c7   # KV namespace: job-agent-state
# AI Gateway proxies Groq + OpenAI (caching, rate-limit dashboard)
# Workers AI provides free llama-3.3-70b for Scout_Beta, Strategy_Alpha, Intel_Beta
# KV persists applied_jobs + posted_groups in the cloud (survives device restarts)

# ─── Web Search ───────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...              # https://tavily.com  (FREE tier)
X_BEARER_TOKEN=                      # Optional: X/Twitter API for live job tweets

# ─── Agent Behavior ───────────────────────────────────────────────
AGENT_LANGUAGE=en
AGENT_PERSONA=Professional, sharp, concise. Sounds human, never robotic.
MAX_DM_PER_HOUR=10
MAX_GROUP_POSTS_PER_HOUR=5
RATE_LIMIT_SLEEP=3
AUTO_RESPOND=true
JOB_KEYWORDS=developer,engineer,remote,blockchain
