# Copy to .env and fill in your values

# ── SMMFollows panel ──────────────────────────────────────────────────────────
SMM_API_KEY=YOUR_SMMFOLLOWS_API_KEY
SMM_USER=your_username
SMM_PASS=your_password

# ── SMMWiz panel (fallback) ───────────────────────────────────────────────────
SMMWIZ_API_KEY=YOUR_SMMWIZ_API_KEY
SMMWIZ_USER=your_smmwiz_username
SMMWIZ_PASS=your_smmwiz_password

# ── AstraSMM panel (last resort) ─────────────────────────────────────────────
ASTRA_API_KEY=YOUR_ASTRASMM_API_KEY
ASTRA_USER=your_astrasmm_username
ASTRA_PASS=your_astrasmm_password

# ── Cloudflare Workers AI ─────────────────────────────────────────────────────
# Create at https://dash.cloudflare.com → My Profile → API Tokens
DEEPSEEK_API_KEY=cfut_YOUR_CLOUDFLARE_AI_TOKEN
CF_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
CF_AI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
CF_GATEWAY_ID=smm-sentinel

# ── Cloudflare Global API Key (for provisioning resources) ───────────────────
CF_GLOBAL_API_KEY=YOUR_CLOUDFLARE_GLOBAL_KEY
CF_EMAIL=your@email.com

# ── Apply Pilot (job-application orchestra) ───────────────────────────────────
APPLY_AUTO_SUBMIT=false          # true = actually submit forms (default dry-run)
APPLY_FIRST_NAME=Ashiq
APPLY_LAST_NAME=Ah
APPLY_FULL_NAME=Ashiq Ah
APPLY_EMAIL=naveeddurfi@gmail.com
APPLY_PHONE=
APPLY_SALARY=Negotiable, aligned with market rate for the role
APPLY_NOTICE=Immediately available
APPLY_PORTFOLIO=
APPLY_GITHUB=

# ── Anthropic / Claude (fallback AI) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY

# ── Solana Meme-Coin Trading Bot (sol_meme_bot.py) ───────────────────────────
# Paper trading by default. Set SOLBOT_LIVE=true ONLY when you understand the
# risks — meme coins are extremely volatile and most go to zero.
SOLBOT_LIVE=false
SOLBOT_RPC_URL=https://api.mainnet-beta.solana.com
# Base58 private key (Phantom export). Required only when SOLBOT_LIVE=true.
# Use a dedicated burner wallet funded with only what you can afford to lose.
SOLBOT_PRIVATE_KEY=
SOLBOT_BUY_AMOUNT_SOL=0.05
SOLBOT_MAX_POSITIONS=5
SOLBOT_MAX_DAILY_BUYS=20
SOLBOT_TAKE_PROFIT_PCT=60
SOLBOT_STOP_LOSS_PCT=25
SOLBOT_TRAILING_STOP_PCT=20
SOLBOT_MAX_HOLD_MINUTES=240
SOLBOT_MIN_LIQUIDITY_USD=20000
SOLBOT_MIN_VOLUME_H1_USD=10000
SOLBOT_SLIPPAGE_BPS=300
# Optional Telegram trade alerts
SOLBOT_TG_BOT_TOKEN=
SOLBOT_TG_CHAT_ID=

# ── Telegram API (for telegram_agents/) ──────────────────────────────────────
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+1234567890
TELEGRAM_SESSION_NAME=my_session

# ── AI Providers (telegram_agents/) ──────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── Agent Behavior (telegram_agents/) ────────────────────────────────────────
AGENT_LANGUAGE=en
AGENT_PERSONA=Professional, sharp, concise. Sounds human, never robotic.
MAX_DM_PER_HOUR=10
MAX_GROUP_POSTS_PER_HOUR=5
RATE_LIMIT_SLEEP=3
AUTO_RESPOND=true
JOB_KEYWORDS=python developer,blockchain engineer,backend engineer,remote developer
SERPAPI_KEY=
