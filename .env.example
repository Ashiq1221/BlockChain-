# Copy to .env and fill in your values
# Activate: export $(grep -v '^#' .env | xargs)

# Your SMMFollows API key
# → Log in at https://smmfollows.com  →  Profile menu (top-right)  →  API
SMM_API_KEY=YOUR_SMMFOLLOWS_API_KEY

# Anthropic / Claude API key (AI comment generation & decision making)
# → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ── Verified Twitter/X service IDs (from your panel) ──────────────────────
# ID 12452 → Twitter Likes Turkey HQ    | $0.88/1k | refill:YES | min:10
# ID 7339  → Twitter Comments Custom USA | $33.75/1k             | min:5
# ID 13139 → Twitter Retweets HQ         | $0.54/1k | refill:YES | min:10
SMM_LIKES_SVC=12452
SMM_COMMENTS_SVC=7339
SMM_RETWEETS_SVC=13139

# Quantities per order
SMM_LIKES_QTY=50
SMM_COMMENTS_QTY=5
SMM_RETWEETS_QTY=10

# Comma-separated Twitter/X post URLs to boost
SMM_TARGET_LINKS=https://twitter.com/yourhandle/status/000000000000000000
